{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/publish",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/generate-daily",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/refresh-metrics",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sitemap-refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/silverback-drain",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
