# Neon Postgres — pooled (DATABASE_URL) + direct (DATABASE_URL_DIRECT for migrations).
DATABASE_URL=
DATABASE_URL_DIRECT=

# Badger — sibling-app integration. Same value must be set in Badger as well.
BADGER_BASE_URL=https://badger-gray.vercel.app
BADGER_API_KEY=

# Z.AI GLM (phase 3 — content generation).
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.6

# Cron secret — gates /api/cron/* in phase 4.
CRON_SECRET=

PUBLIC_URL=http://localhost:3000

# Credential vault — `openssl rand -hex 32` to generate. Required in prod.
INTEGRATION_ENCRYPTION_KEY=
# Optional override; defaults to INTEGRATION_ENCRYPTION_KEY if absent.
OAUTH_STATE_SECRET=

# Per-channel OAuth applications. Register one app per channel-group;
# Spider uses the same app for every Spider client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
