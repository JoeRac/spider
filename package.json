{
  "name": "spider",
  "version": "0.1.0",
  "private": true,
  "description": "Workflow + content hub for agency clients — multi-channel publishing, AI content generation, SEO fulfillment",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "node --env-file=.env.local --import=tsx scripts/seed.ts",
    "seed:demo": "node --env-file=.env.local --import=tsx scripts/seed-demo.ts",
    "import:badger": "node --env-file=.env.local --import=tsx scripts/import-badger.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/react-query": "^5.62.7",
    "@vercel/blob": "^2.3.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.2",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
